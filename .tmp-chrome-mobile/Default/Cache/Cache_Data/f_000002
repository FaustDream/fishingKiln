const categoryLeadMap = {
  tea: "把点茶、泡饮、分饮与杯碟套组放回同一条慢饮秩序里理解。",
  tableware: "用桌面分工、版式结构与海贸流通重新整理盘、碗、碟的阅读路径。",
  coffee: "把冲煮系统、参数矩阵、跨文化器物史与共享详情面板并排组织成一个正式入口。",
  vase: "从插枝、空间尺度与器身轮廓进入花器的静气与陈设秩序。",
  art: "围绕题景、收藏与正式观看，建立艺术品页的策展入口。"
};

function buildCategoryOverview(items) {
  return items.map((item) => ({
    slug: item.slug,
    title: item.name,
    href: item.href,
    summary: categoryLeadMap[item.slug] ?? item.intro ?? item.historyNote ?? "",
    stats:
      item.summaryStats?.slice(0, 2) ??
      [
        ["1 条", "栏目入口"],
        [`${item.relatedResearchIds?.length ?? 0} 条`, "延伸阅读"]
      ]
  }));
}

function buildResearchMap(items) {
  return new Map(items.map((item) => [item.id, item]));
}

function pickResearchItems(ids, lookup) {
  return [...new Set(ids)].map((id) => lookup.get(id)).filter(Boolean);
}

function buildCoffeeSourceDeck(category) {
  return {
    title: category.detailDeck.title,
    summary: "首页与咖啡页共用同一套冲煮详情，先看协议，再回到具体器具和来源页面。",
    items: category.detailDeck.items.slice(0, 6)
  };
}

function buildCoffeeFeaturedRecords(lookup) {
  return [
    "manual-brewing-protocol",
    "espresso-pressure-workflow",
    "export-coffee-pot",
    "worcester-coffee-pot",
    "ottoman-coffee-culture"
  ]
    .map((id) => lookup.get(id))
    .filter(Boolean)
    .map((item) => ({
      id: `record-${item.id}`,
      eyebrow: item.era,
      title: item.title,
      summary: item.summary,
      imagePath: item.imagePath,
      sourceName: item.sourceName,
      sourceUrl: item.sourceUrl,
      detailMeta: [
        ["来源体系", item.sourceType],
        ["时段", item.periods?.join(" / ") ?? item.era],
        ["关联栏目", "咖啡具"]
      ],
      detailFacts: item.keyFacts ?? []
    }));
}

function buildCoffeeTimeline(lookup) {
  return [
    "ottoman-coffee-culture",
    "export-coffee-pot",
    "worcester-coffee-pot",
    "manual-brewing-protocol",
    "espresso-pressure-workflow",
    "cold-brew-concentrate"
  ]
    .map((id) => lookup.get(id))
    .filter(Boolean)
    .map((item) => ({
      id: item.id,
      era: item.era,
      title: item.title,
      summary: item.summary,
      detail: item.lead ?? item.summary,
      facts: item.keyFacts ?? [],
      relatedCategories: item.relatedCategories ?? ["coffee"],
      researchId: item.id
    }));
}

